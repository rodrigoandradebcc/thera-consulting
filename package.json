{
  "name": "ovgs",
  "version": "1.0.0",
  "description": "OVGS — Sistema de Gestão de Ordens de Venda",
  "private": true,
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @ovgs/api db:migrate",
    "db:seed": "pnpm --filter @ovgs/api db:seed",
    "db:reset": "pnpm --filter @ovgs/api db:reset",
    "api:dev": "pnpm --filter @ovgs/api start:dev",
    "api:build": "pnpm --filter @ovgs/api build",
    "test": "pnpm --filter @ovgs/api test",
    "test:e2e": "pnpm --filter @ovgs/api test:e2e"
  }
}
